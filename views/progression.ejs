<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>ความก้าวหน้า - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-4xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-2">ความก้าวหน้า</h1>

        <%
            let totalCourses = courses.length;
            let completedCourses = courses.filter(course => {
                let cc = contents.filter(c => c.course_id == course.course_id);
                return cc.length > 0 && cc.every(c => completedIds.includes(c.content_id));
            }).length;
            let overallPercent = totalCourses > 0 ? Math.round((completedCourses / totalCourses) * 100) : 0;
        %>

        <div class="border rounded-xl p-5 mb-8">
            <div class="flex items-center justify-between mb-3">
                <p class="text-sm font-bold text-gray-700">เรียนจบแล้ว</p>
                <p class="text-sm font-bold text-gray-900"><%= completedCourses %>/<%= totalCourses %> บทเรียน</p>
            </div>
            <div class="w-full bg-gray-500 rounded-full h-2.5">
                <div class="bg-blue-500 h-2.5 rounded-full transition-all" style="width: <%= overallPercent %>%"></div>
            </div>
        </div>

        <% if (courses.length == 0) { %>
        <div class="text-center py-16 text-gray-400">
            <p class="text-sm">ยังไม่มีบทเรียนที่ลงทะเบียนไว้</p>
            <a href="/course" class="mt-4 inline-block text-xs px-4 py-2 bg-blue-600 text-white rounded-xl">ดูบทเรียน</a>
        </div>
        <% } else { %>
        <h2 class="text-base font-bold text-gray-700 mb-4">รายวิชา</h2>
        <div class="flex flex-col gap-4">
            <% courses.forEach((course) => {
                let courseContents = contents.filter(c => c.course_id == course.course_id);
                let courseDone = courseContents.filter(c => completedIds.includes(c.content_id)).length;
                let courseTotal = courseContents.length;
                let coursePercent = courseTotal > 0 ? Math.round((courseDone / courseTotal) * 100) : 0;
                let barColor = coursePercent < 25 ? "red" : coursePercent < 50 ? "orange" : coursePercent < 75 ? "yellow" : "green";
            %>
            <div class="border border-l-8 border-l-<%= course.color %>-600 rounded-xl shadow-sm overflow-hidden">
                <div class="p-5">
                    <div class="flex items-start justify-between mb-2">
                        <div>
                            <h3 class="font-bold text-base text-black"><%= course.title %></h3>
                            <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-white mt-1 inline-block"><%= course.catagory_name %></span>
                        </div>
                        <div class="text-right flex-shrink-0 ml-4">
                            <p class="text-lg font-bold text-gray-800"><%= coursePercent %>%</p>
                            <p class="text-xs text-gray-400"><%= courseDone %>/<%= courseTotal %> บท</p>
                        </div>
                    </div>
                    <div class="w-full bg-gray-600 rounded-full mt-3 mb-4">
                        <div class="bg-<%= barColor %>-600 h-1.5 rounded-full" style="width: <%= coursePercent %>%"></div>
                    </div>
                    <% if (courseContents.length > 0) { %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <% courseContents.forEach((item) => {
                            let done = completedIds.includes(item.content_id);
                        %>
                        <a href="/library/<%= course.course_id %>?content=<%= item.content_id %>"
                           class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs <%= done ? 'bg-green-50 text-green-700' : 'bg-gray-50 text-gray-500' %>">
                            <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-white text-xs font-bold <%= done ? 'bg-green-600' : 'bg-gray-500' %>"></span>
                            <span class="truncate"><%= item.topic %></span>
                        </a>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>
</body>
</html>
