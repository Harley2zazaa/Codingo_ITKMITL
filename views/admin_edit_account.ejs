<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>แก้ไขบัญชี - Codingo</title>
</head>
<body class="bg-white">
    <%- include("partials/header") %>
    <div class="flex items-center justify-center p-6 pt-24 min-h-screen">
        <div class="w-full max-w-lg">
            <a href="/admin" class="text-sm text-gray-600 mb-6 inline-block"><-- ย้อนกลับ</a>
            <h1 class="text-3xl mb-2">แก้ไขบัญชี</h1>
            <p class="text-gray-600 mb-8">แก้ไขบัญชีในระบบ</p>
            <div class="border rounded-xl p-6 shadow-md">
                <form action="/admin/edit/<%= profileUser.account_id %>" method="POST" onsubmit="return confirm('บันทึกข้อมูลใช่หรือไม่')">
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">ชื่อผู้ใช้</label>
                        <input type="text" name="username" value="<%= profileUser.username %>" placeholder="username" required class="w-full px-4 py-3 border rounded-xl text-sm text-gray-800 placeholder-gray-600"/>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">อีเมล</label>
                        <input type="email" name="email" value="<%= profileUser.email %>" placeholder="name@email.com" required class="w-full px-4 py-3 border rounded-xl text-sm text-gray-800 placeholder-gray-600"/>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">รหัสผ่าน</label>
                        <input type="password" name="password" value="<%= profileUser.password %>" placeholder="**********" required class="w-full px-4 py-3 border rounded-xl text-sm text-gray-800 placeholder-gray-600"/>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">บทบาท</label>
                        <select name="role" class="w-full px-4 py-3 border rounded-xl text-sm text-gray-800 placeholder-gray-600">
                            <option value="student" <%= profileUser.role == "student" ? 'selected' : '' %>>student</option>
                            <option value="instructor" <%= profileUser.role == "instructor" ? 'selected' : '' %>>instructor</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full px-4 py-3 bg-blue-600 text-white text-sm rounded-xl">บันทึก</button>
                </form>
            </div>
        </div>
    </div>
    <% if (success) { %>
    <script>alert("บันทึกข้อมูลเรียบร้อย");</script>
    <% } else if (error) { %>
    <script>alert("<%= error %>");</script>
    <% } %>
</body>
</html>
