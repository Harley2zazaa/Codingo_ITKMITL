<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>แก้ไขบทเรียน - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-2xl mx-auto px-6 py-10 min-h-screen">
        <a href="/instructor" class="text-sm text-gray-500 mb-6 inline-block">← กลับหน้าจัดการเนื้อหา</a>
        <h1 class="text-3xl font-bold mb-8">แก้ไขบทเรียน</h1>
        <div class="bg-white border rounded-2xl p-7 mb-8">
            <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-5">
                <%= error %>
            </div>
            <% } %>
            <form action="/instructor/edit/<%= course.course_id %>" method="POST">
                <div class="mb-5">
                    <label class="block text-sm text-gray-500 mb-1.5">ชื่อบทเรียน <span class="text-red-400">*</span></label>
                    <input type="text" name="title" value="<%= course.title %>" required class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                </div>
                <div class="mb-5">
                    <label class="block text-sm text-gray-500 mb-1.5">คำอธิบาย <span class="text-red-400">*</span></label>
                    <textarea name="description" rows="3" required class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none resize-none"><%= course.description %></textarea>
                </div>
                <div class="mb-7">
                    <label class="block text-sm text-gray-500 mb-1.5">หมวดหมู่</label>
                    <select name="catagory_id" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none">
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.catagory_id %>" <%= course.catagory_id == cat.catagory_id ? 'selected' : '' %>><%= cat.catagory_name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="flex gap-3">
                    <button type="submit" class="bg-green-600 text-white px-6 py-2.5 rounded-lg text-sm">บันทึกการแก้ไข</button>
                    <a href="/instructor" class="px-6 py-2.5 text-sm text-gray-500 border rounded-lg">ยกเลิก</a>
                </div>
            </form>
        </div>

        <div class="flex items-center justify-between mb-4">
            <h2 class="font-bold text-lg">เนื้อหาทั้งหมด (<%= contents.length %> บท)</h2>
            <a href="/instructor/create/<%= course.course_id %>" class="bg-blue-500 text-white px-4 py-2 rounded-lg text-sm">+ เพิ่มเนื้อหา</a>
        </div>
        <% if (contents.length == 0) { %>
            <div class="text-center text-gray-500 py-10 bg-white border rounded-xl">ยังไม่มีเนื้อหา</div>
        <% } else { %>
            <div class="flex flex-col gap-3">
                <% contents.forEach((item, index) => { %>
                    <div class="bg-white border rounded-xl p-5">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex items-start gap-3 flex-1 min-w-0">
                                <span class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-full bg-gray-700 text-xs font-bold text-white"><%= index + 1 %></span>
                                <div class="min-w-0 flex-1">
                                    <p class="font-semibold text-sm text-black"><%= item.topic %></p>
                                    <p class="text-xs text-gray-500 mt-1 line-clamp-2"><%= item.content || '(ไม่มีเนื้อหา)' %></p>
                                    <% if (item.Questions) { %>
                                        <div class="mt-2 bg-gray-50 border rounded-lg px-3 py-2">
                                            <p class="text-xs font-semibold text-gray-600"><%= item.Questions %></p>
                                            <p class="text-xs text-gray-500 mt-1">A: <%= item.A %> &nbsp; B: <%= item.B %> &nbsp; C: <%= item.C %> &nbsp; D: <%= item.D %></p>
                                            <p class="text-xs text-green-600 font-semibold mt-1">เฉลย: <%= item.Answer %></p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                <a href="/instructor/edit/<%= item.course_id %>/<%= item.content_id %>" class="text-xs px-3 py-1.5 bg-blue-500 border border-blue-500 rounded-md text-white">แก้ไข</a>
                                <form action="/instructor/delete/<%= item.course_id %>/<%= item.content_id %>" method="POST" onsubmit="return confirm('ลบเนื้อหานี้ใช่หรือไม่?')">
                                    <button type="submit" class="text-xs px-3 py-1.5 bg-red-600 border border-red-600 rounded-md text-white">ลบ</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</body>
</html>
