<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>เพิ่มบทเรียน - Codingo</title>
</head>
<body class="bg-white">
    <%- include('partials/header') %>
    <div class="max-w-4xl mx-auto p-6 pt-24 min-h-screen">
        <a href="/instructor" class="text-sm text-gray-600 mb-6 inline-block"><-- ย้อนกลับ</a>
        <h1 class="text-3xl text-gray-800 mb-1">เพิ่มบทเรียนใหม่</h1>
        <p class="text-gray-600 mb-6">เพิ่มบทเรียนในระบบ</p>
        <div class="bg-white border rounded-xl p-8 shadow-md">
            <form action="/instructor/create" method="POST">
                <div class="mb-4">
                    <label class="block text-sm text-gray-600 mb-2">ชื่อบทเรียน <span class="text-red-600">*</span></label>
                    <input type="text" name="title" placeholder="เช่น HTML พื้นฐาน" required class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-600"/>
                </div>
                <div class="mb-4">
                    <label class="block text-sm text-gray-600 mb-2">คำอธิบาย <span class="text-red-600">*</span></label>
                    <textarea name="description" rows="3" placeholder="อธิบายเนื้อหาของบทเรียนนี้" required class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-600 resize-none"></textarea>
                </div>
                <div class="mb-6">
                    <label class="block text-sm text-gray-600 mb-2">หมวดหมู่</label>
                    <select name="catagory_id" class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800">
                        <% categories.forEach(cat => { %>
                        <option value="<%= cat.catagory_id %>"><%= cat.catagory_name %></option>
                        <% }); %>
                    </select>
                </div>
                <button type="submit" class="w-full bg-green-600 text-white px-4 py-3 rounded-xl text-sm">เพิ่มบทเรียน</button>
            </form>
        </div>
    </div>
</body>
</html>
