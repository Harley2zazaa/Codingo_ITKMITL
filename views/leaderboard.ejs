<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Codingo — Leaderboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>* { font-family: 'Sarabun', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">

  <%- include('partials/navbar') %>

  <div class="max-w-2xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold mb-2">🏆 Leaderboard</h1>
    <p class="text-gray-400 mb-8">อันดับนักศึกษาตามคะแนนสะสม</p>

    <% if (empty) { %>
      <div class="text-center py-20">
        <p class="text-gray-400">ยังไม่มีข้อมูลอันดับในขณะนี้</p>
      </div>
    <% } else { %>
      <div class="flex flex-col gap-3">
        <% board.forEach((item, index) => { %>
          <%
            const medals = ['🥇','🥈','🥉'];
            const isMe   = user && user.id === item.id;
          %>
          <div class="flex items-center gap-4 bg-gray-800 border <%= isMe ? 'border-yellow-400' : 'border-gray-700' %> rounded-xl px-5 py-4">
            <!-- อันดับ -->
            <div class="w-9 text-center text-lg font-bold flex-shrink-0">
              <% if (index < 3) { %>
                <%= medals[index] %>
              <% } else { %>
                <span class="text-gray-500 text-sm">#<%= index + 1 %></span>
              <% } %>
            </div>
            <!-- ชื่อ -->
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sm text-white">
                <%= item.nickname || item.username %>
                <% if (isMe) { %><span class="text-yellow-400 text-xs ml-1">(คุณ)</span><% } %>
              </p>
              <p class="text-xs text-gray-500"><%= item.lessons_count %> บทเรียนในคลัง</p>
            </div>
            <!-- คะแนน -->
            <div class="text-right">
              <p class="text-lg font-bold text-yellow-400"><%= item.score %></p>
              <p class="text-xs text-gray-500">คะแนน</p>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
