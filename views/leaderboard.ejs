<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>ตารางอันดับ - Codingo</title>
</head>
<body class="bg-white">
    <%- include("partials/header") %>
    <div class="max-w-4xl mx-auto p-6 pt-24 min-h-screen">
        <h1 class="text-3xl text-gray-800 mb-2">ตารางอันดับ</h1>
        <p class="text-gray-600 mb-8">อันดับนักศึกษาตาม XP สะสม</p>
        <div class="flex flex-col gap-4">
            <% accounts.forEach((item, index) => { %>
            <% const isMe = user && user.account_id == item.account_id; %>
            <div class="flex items-center gap-4 bg-white border border-l-8 <%= isMe ? 'border-l-orange-600' : 'border-l-blue-600' %> shadow-md rounded-xl px-5 py-4">
                <div class="text-left">
                    <span class="text-gray-800 text-md">#<%= index + 1 %></span>
                </div>
                <div class="flex-1 text-center">
                    <p class="text-lg text-gray-800"><%= item.username %></p>
                    <p class="text-xs text-gray-600"><%= item.email %></p>
                </div>
                <div class="text-right">
                    <p class="text-lg <%= isMe ? 'text-orange-600' : 'text-blue-600' %>"><%= item.xp %> XP</p>
                    <p class="text-xs text-gray-800">Lv. <%= item.level %></p>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</body>
</html>
