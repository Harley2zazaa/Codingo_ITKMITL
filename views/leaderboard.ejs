<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>ตารางอันดับ - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/navbar') %>
    <div class="max-w-2xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-2">ตารางอันดับ</h1>
        <p class="text-gray-500 mb-8">อันดับนักศึกษาตามคะแนนสะสม</p>
        <% if (empty) { %>
            <div class="text-center py-20">
                <p class="text-gray-500">ยังไม่มีข้อมูลอันดับในขณะนี้</p>
            </div>
        <% } else { %>
            <div class="flex flex-col gap-3">
            <% board.forEach((item, index) => { %>
                <% const isMe = user && user.id == item.id; %>
                <div class="flex items-center gap-4 bg-white border border-l-8 <%= (isMe) ? 'border-l-orange-500': 'border-l-blue-500'; %> shadow-md rounded-xl px-5 py-4">
                    <div class="w-9 text-center text-lg font-bold flex-shrink-0">
                        <span class="text-gray-500 text-sm">#<%= index + 1 %></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-sm text-black"><%= item.username %><% if (isMe) { %><span class="text-orange-500 text-xs ml-1">(คุณ)</span><% } %></p>
                        <p class="text-xs text-gray-500"><%= item.course_count %> บทเรียนในคลัง</p>
                    </div>
                    <div class="text-right">
                        <p class="text-lg font-bold <%= (isMe) ? 'text-orange-500': 'text-blue-500'; %>"><%= item.score %></p>
                        <p class="text-xs text-gray-500">คะแนน</p>
                    </div>
                </div>
            <% }); %>
            </div>
        <% } %>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
