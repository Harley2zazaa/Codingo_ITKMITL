<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>ตารางอันดับ - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-2xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-2">ตารางอันดับ</h1>
        <p class="text-gray-500 mb-8">อันดับนักศึกษาตาม XP สะสม</p>
        <div class="flex flex-col gap-3">
            <% accounts.forEach((item, index) => { %>
            <% const isMe = user && user.account_id == item.account_id; %>
            <div class="flex items-center gap-4 bg-white border border-l-8 <%= isMe ? 'border-l-orange-500' : 'border-l-blue-500' %> shadow-md rounded-xl px-5 py-4">
                <div class="w-9 text-center text-lg font-bold flex-shrink-0">
                    <span class="text-gray-500 text-sm">#<%= index + 1 %></span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-semibold text-sm text-black"><%= item.username %><% if (isMe) { %><span class="text-orange-500 text-xs ml-1">(คุณ)</span><% } %></p>
                    <p class="text-xs text-gray-500"><%= item.email %></p>
                </div>
                <div class="text-right">
                    <p class="text-lg font-bold <%= isMe ? 'text-orange-500' : 'text-blue-500' %>"><%= item.xp || 0 %></p>
                    <p class="text-xs text-gray-500">XP</p>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</body>
</html>
