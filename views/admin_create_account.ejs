<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>สร้างบัญชี - Codingo</title>
</head>
<body class="bg-white">
	<%- include("partials/header") %>
    <div class="flex items-center justify-center p-6 pt-24 min-h-screen">
        <div class="w-full max-w-md">
            <a href="/admin" class="text-sm text-gray-600 mb-6 inline-block"><-- ย้อนกลับ</a>
			<h1 class="text-3xl mb-2">สร้างบัญชี</h1>
            <p class="text-gray-600 mb-8">สร้างบัญชีในระบบ</p>
            <div class="bg-white border shadow-md rounded-2xl p-8">
                <form action="/admin/create" method="POST" onsubmit="return confirm('ต้องการสร้างบัญชีใหม่ใช่หรือไม่')">
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">ชื่อผู้ใช้</label>
                        <input type="text" name="username" placeholder="username" required class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-600"/>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">อีเมล</label>
                        <input type="email" name="email" placeholder="name@email.com" required class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-600"/>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm text-gray-600 mb-2">รหัสผ่าน</label>
                        <input type="password" name="password" placeholder="**********" required class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-600"/>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-2">บทบาท</label>
                        <select name="role" required class="w-full bg-white border rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-600">
                            <option value="student">student</option>
                            <option value="instructor">instructor</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full bg-blue-600 text-white text-sm px-4 py-3 rounded-xl">สร้างบัญชี</button>
                </form>
            </div>
        </div>
    </div>
    <% if (error) { %>
    <script>alert("<%= error %>");</script>
    <% } %>
</body>
</html>
