<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>หน้าหลัก - Codingo</title>
</head>
<body class="bg-white">
    <%- include("partials/header") %>
    <div class="flex justify-center items-center px-6 text-center min-h-screen">
