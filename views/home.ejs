            <div class="flex gap-4 justify-center">
                <a href="/<%- user ? 'library': 'signin' %>" class="bg-gray-800 text-white px-4 py-3 rounded-xl text-sm"><%- user ? "คลังของฉัน": "เริ่มเรียนเลย" %></a>
                <a href="/course" class="border px-4 py-3 rounded-xl text-sm">ค้นหาบทเรียน</a>
