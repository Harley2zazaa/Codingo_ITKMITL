<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>บทเรียน - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-6xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-1">บทเรียน</h1>
        <p class="text-gray-500 mb-6">ค้นหาจากชื่อ หรือหมวดหมู่</p>
        <form class="flex gap-3 mb-8" action="/course" method="POST">
            <input type="text" name="search" value="<%= search %>" placeholder="พิมพ์คำค้นหา" class="flex-1 bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none"/>
            <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded-xl text-sm">ค้นหา</button>
        </form>
        <p class="text-sm text-gray-500 mb-4">พบบทเรียนทั้งหมด <%= courses.length %> บทเรียน</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            <% courses.forEach((item) => { %>
                <a href="/course/<%= item.course_id %>" class="block bg-white border border-l-8 border-l-<%= item.color %>-500 rounded-xl shadow-md overflow-hidden">
                    <div class="p-5">
                        <h2 class="font-bold text-base text-black mb-1"><%= item.title %></h2>
                        <div class="flex items-center justify-between my-2">
                            <span class="text-xs px-2 py-1 rounded-full bg-gray-700 text-white"><%= item.catagory_name %></span>
                        </div>
                        <p class="text-sm text-gray-500 line-clamp-2"><%= item.description %></p>
                    </div>
                </a>
            <% }); %>
        </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
