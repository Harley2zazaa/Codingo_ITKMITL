<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title><%= course.title %> - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/navbar') %>
    <div class="max-w-3xl mx-auto px-6 py-10 min-h-screen">
        <a href="/search" class="text-sm text-gray-500 mb-6 inline-block">← ย้อนกลับ</a>
        <% if (msg == 'added') { %><div class="bg-green-900 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">เพิ่มบทเรียนเข้าคลังสำเร็จ</div><% } %>
        <% if (msg == 'removed') { %><div class="bg-red-700 border border-red-500 text-gray-300 text-sm rounded-lg px-4 py-3 mb-5">ถอนบทเรียนออกจากคลังแล้ว</div><% } %>
        <% if (msg == 'already') { %><div class="bg-yellow-900 border border-yellow-500 text-yellow-300 text-sm rounded-lg px-4 py-3 mb-5">บทเรียนนี้อยู่ในคลังแล้ว</div><% } %>
        <% if (msg == 'completed') { %><div class="bg-green-900 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">บันทึกความก้าวหน้าสำเร็จ (+20 แต้ม)</div><% } %>
        <div class="bg-white border border-l-8 border-l-<%= course.color %>-500 shadow-md rounded-2xl p-7 mb-6">
            <span class="text-xs px-2.5 py-1 rounded-full bg-gray-700 text-white"><%= course.category %></span>
            <h1 class="text-2xl font-bold text-black mt-3 mb-2"><%= course.title %></h1>
            <p class="text-gray-500 text-sm mb-5"><%= course.description %></p>
            <% if (user) { %>
                <% if (!inLibrary) { %>
                    <form method="POST" action="/library/add/<%= course.id %>" class="inline" onsubmit="return confirm('เพิ่มบทเรียนนี้เข้าในคลังใช่หรือไม่?')">
                        <button type="submit" class="bg-green-600 text-white text-sm px-5 py-2 rounded-lg">+ เพิ่มเข้าคลัง</button>
                    </form>
                <% } else { %>
                    <form method="POST" action="/library/remove/<%= course.id %>" class="inline" onsubmit="return confirm('ถอนบทเรียนนี้ออกจากคลังใช่หรือไม่?')">
                        <button type="submit" class="bg-red-600 text-white text-sm px-5 py-2 rounded-lg">✕ ถอนจากคลัง</button>
                    </form>
                <% } %>
            <% } else { %>
                <a href="/login" class="inline-block bg-blue-500 text-white text-sm px-5 py-2 rounded-lg">เข้าสู่ระบบ</a>
            <% } %>
        </div>
        <h2 class="text-lg font-bold mb-4">เนื้อหาในบทเรียน <%= contents.length %> บท</h2>
        <% if (contents.length == 0) { %>
            <div class="bg-white border shadow-md rounded-xl p-8 text-center text-gray-500">ไม่มีเนื้อหาบทเรียน</div>
        <% } else { %>
            <% contents.forEach((item, index) => { %>
                <% const isDone = completedIds.includes(item.id) %>
                <% if (!user || !inLibrary) { %>
                <div class="flex items-center gap-3 px-5 py-4 bg-white border shadow-md rounded-xl mb-3 cursor-pointer no-underline">
                    <span class="w-7 h-7 flex items-center justify-center rounded-full text-xs flex-shrink-0 bg-gray-700 text-white"><%= index + 1 %></span>
                    <span class="font-semibold text-sm flex-1 text-black"><%= item.title %></span>
                    <span class="text-gray-400 text-xs"><%= !user ? 'เข้าสู่ระบบ' : 'เพิ่มเข้าคลัง' %></span>
                </div>
                <% } else { %>
                <details class="bg-white border shadow-md rounded-xl mb-3 overflow-hidden group">
                    <summary class="flex items-center gap-3 px-5 py-4">
                        <span class="w-7 h-7 flex items-center justify-center rounded-full text-xs flex-shrink-0 <%= isDone ? 'bg-green-500 text-white' : 'bg-gray-700 text-white' %>"><%= isDone ? '✓' : index + 1 %></span>
                        <span class="font-semibold text-sm flex-1"><%= item.title %></span>
                    </summary>
                    <div class="px-5 pb-5 pt-2 border-t">
                        <p class="text-gray-500 text-sm leading-relaxed mb-4"><%= item.body || 'ยังไม่มีเนื้อหา' %></p>
                        <% if (item.Questions) { %>
                        <div class="bg-gray-50 border rounded-xl p-4 mb-4">
                            <p class="text-sm font-semibold text-gray-700 mb-3"><%= item.Questions %></p>
                            <div class="grid grid-cols-1 gap-2">
                                <% [['A', item.A], ['B', item.B], ['C', item.C], ['D', item.D]].forEach(([key, val]) => { %>
                                    <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                                        <input type="radio" name="quiz_<%= item.id %>" value="<%= key %>" class="accent-blue-500" />
                                        <span class="font-semibold"><%= key %>.</span> <%= val %>
                                    </label>
                                <% }); %>
                            </div>
                            <button type="button" onclick="checkAnswer(this, '<%= item.Answer %>', <%= item.id %>, <%= (user && inLibrary && !isDone) ? 'true' : 'false' %>)" class="mt-3 text-xs bg-blue-500 text-white px-4 py-1.5 rounded-lg">ตรวจคำตอบ</button>
                            <p class="quiz-result text-xs mt-2 hidden"></p>
                        </div>
                        <% } %>
                        <% if (isDone) { %>
                            <span class="text-xs text-green-400">เรียนจบแล้ว</span>
                        <% } %>
                    </div>
                </details>
                <% } %>
            <% }); %>
        <% } %>
    </div>
    <%- include('partials/footer') %>
    <script>
        function checkAnswer(btn, correctAnswer, contentId, canComplete) {
            const container = btn.closest('.bg-gray-50');
            const selected = container.querySelector('input[type="radio"]:checked');
            const result = container.querySelector('.quiz-result');
            result.classList.remove('hidden');
            if (!selected) {
                result.textContent = 'กรุณาเลือกคำตอบก่อน';
                result.className = 'quiz-result text-xs mt-2 text-yellow-500';
                return;
            }
            if (selected.value == correctAnswer) {
                result.textContent = 'ถูกต้อง';
                result.className = 'quiz-result text-xs mt-2 text-green-500 font-semibold';
                if (canComplete) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = `/progress/complete/${contentId}`;
                    document.body.appendChild(form);
                    form.submit();
                }
            } else {
                result.textContent = 'ผิด ลองใหม่อีกครั้ง';
                result.className = 'quiz-result text-xs mt-2 text-red-500 font-semibold';
            }
        }
    </script>
</body>
</html>
