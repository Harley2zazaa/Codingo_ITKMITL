<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>ค้นหาบทเรียน - Codingo</title>
</head>
<body class="bg-white">
    <%- include('partials/navbar') %>
    <div class="max-w-6xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-1">ค้นหาบทเรียน</h1>
        <p class="text-gray-500 mb-6">ค้นหาจากชื่อ คำอธิบาย หรือหมวดหมู่</p>
        <form class="flex gap-3 mb-8" action="/search" method="GET">
            <input type="text" name="q" value="<%= keyword %>" placeholder="พิมพ์คำค้นหา..." class="flex-1 bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none"/>
            <button type="submit" class="bg-blue-500 text-white px-6 py-2.5 rounded-lg text-sm">ค้นหา</button>
        </form>
        <% if (notFound) { %>
            <div class="text-center py-20">
                <p class="text-gray-500 text-lg font-semibold">ไม่พบบทเรียน</p>
                <p class="text-gray-600 text-sm mt-1">ลองใช้คำค้นหาอื่น หรือลองเปลี่ยนหมวดหมู่</p>
            </div>
        <% } else if (course.length) { %>
            <p class="text-sm text-gray-500 mb-4">พบ <%= course.length %> บทเรียน</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                <% course.forEach((item) => { %>
                    <a href="/course/<%= item.id %>" class="block bg-white border rounded-xl shadow-md overflow-hidden" style="border-left: 8px solid <%= item.color || '#6b7280' %>">
                        <div class="p-5">
                            <h2 class="font-bold text-base text-black mb-1"><%= item.title %></h2>
                            <div class="flex items-center justify-between my-2">
                                <span class="text-xs font-semibold px-2 py-1 rounded-lg bg-gray-700 text-gray-300"><%= item.category %></span>
                                <span class="text-xs text-gray-500"><%= item.content_count %> หัวข้อ</span>
                            </div>
                            <p class="text-sm text-gray-500 line-clamp-2"><%= item.description %></p>
                        </div>
                    </a>
                <% }); %>
            </div>
        <% } else { %>
            <% if (allCourses.length) { %>
                <p class="text-sm text-gray-500 mb-4">บทเรียนทั้งหมด <%= allCourses.length %> บทเรียน</p>
            <% } %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            <% allCourses.forEach((item) => { %>
                <a href="/course/<%= item.id %>" class="block bg-white border rounded-xl shadow-md overflow-hidden" style="border-left: 8px solid <%= item.color || '#6b7280' %>">
                    <div class="p-5">
                        <h2 class="font-bold text-base text-black mb-1"><%= item.title %></h2>
                        <div class="flex items-center justify-between my-2">
                            <span class="text-xs font-semibold px-2 py-1 rounded-lg bg-gray-700 text-gray-300"><%= item.category %></span>
                            <span class="text-xs text-gray-500"><%= item.content_count %> หัวข้อ</span>
                        </div>
                        <p class="text-sm text-gray-500 line-clamp-2"><%= item.description %></p>
                    </div>
                </a>
            <% }); %>
        </div>
        <% } %>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
