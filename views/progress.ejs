<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Codingo — ความก้าวหน้า</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>* { font-family: 'Sarabun', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">

  <%- include('partials/navbar') %>

  <div class="max-w-3xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold mb-2">ความก้าวหน้าในการเรียน</h1>
    <p class="text-gray-400 mb-8">ติดตามความคืบหน้าของแต่ละบทเรียน</p>

    <% if (empty) { %>
      <div class="text-center py-24">
        <p class="text-5xl mb-3">📊</p>
        <p class="text-gray-400 text-lg font-semibold">ยังไม่มีบทเรียนที่ลงทะเบียนไว้</p>
        <a href="/library" class="inline-block mt-5 bg-yellow-500 hover:bg-yellow-400 text-black font-semibold px-6 py-2.5 rounded-lg text-sm transition">
          ไปที่คลังส่วนตัว
        </a>
      </div>
    <% } else { %>
      <div class="flex flex-col gap-4">
        <% lessons.forEach((item) => { %>
          <%
            const pct = item.total > 0 ? Math.round((item.done / item.total) * 100) : 0;
          %>
          <a href="/lessons/<%= item.id %>" class="block bg-gray-800 border border-gray-700 hover:border-gray-500 rounded-xl p-5 transition">
            <div class="flex items-center justify-between mb-3">
              <div>
                <h2 class="font-bold text-white"><%= item.title %></h2>
                <span class="text-xs text-gray-500"><%= item.category %></span>
              </div>
              <span class="text-lg font-bold <%= pct === 100 ? 'text-green-400' : 'text-yellow-400' %>">
                <%= pct %>%
              </span>
            </div>
            <!-- Progress bar -->
            <div class="h-2 bg-gray-700 rounded-full overflow-hidden mb-2">
              <div class="h-full rounded-full transition-all
                <%= pct === 100 ? 'bg-green-500' : 'bg-yellow-500' %>"
                style="width: <%= pct %>%">
              </div>
            </div>
            <p class="text-xs text-gray-500">
              <%= item.done %>/<%= item.total %> เนื้อหาเสร็จสิ้น
              <% if (pct === 100) { %> ✅ เรียนจบแล้ว<% } %>
            </p>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
