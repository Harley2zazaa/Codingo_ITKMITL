<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>โปรไฟล์ - Codingo</title>
</head>
<body class="bg-white min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <a href="/home" class="text-sm text-gray-400 mb-6 inline-block">← ย้อนกลับ</a>
        <h1 class="text-3xl font-bold mb-2">โปรไฟล์</h1>
        <p class="text-gray-500 mb-8">รายละเอียดส่วนตัว</p>
        <div class="flex items-center gap-4 p-5 border rounded-xl mb-4">
            <p class="w-14 h-14 rounded-full bg-gray-800 flex items-center justify-center text-white text-xl font-bold flex-shrink-0"><%= profileUser.username.charAt(0).toUpperCase() %></p>
            <div>
                <p class="font-bold text-gray-900"><%= profileUser.username %></p>
                <p class="text-xs text-gray-400"><%= profileUser.email %></p>
                <p class="text-xs text-gray-500 mt-1">
                    XP <span class="text-orange-500 font-bold text-sm"><%= gamificate ? gamificate.xp : 0 %></span>
                    &nbsp;·&nbsp; เลเวล <span class="text-blue-500 font-bold text-sm"><%= gamificate ? gamificate.level : 0 %></span>
                    &nbsp;·&nbsp; Streak <span class="text-green-500 font-bold text-sm"><%= gamificate ? gamificate.streak : 0 %></span> วัน
                </p>
            </div>
        </div>
        <div class="border rounded-xl p-6">
            <h2 class="text-sm font-bold text-gray-700 mb-5">แก้ไขข้อมูล</h2>
            <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 text-xs rounded-lg px-4 py-3 mb-4"><%= error %></div>
            <% } %>
            <% if (success) { %>
            <div class="bg-green-50 border border-green-200 text-green-600 text-xs rounded-lg px-4 py-3 mb-4"><%= success %></div>
            <% } %>
            <form method="POST" action="/profile">
                <div class="mb-4">
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">ชื่อผู้ใช้</label>
                    <input type="text" name="username" value="<%= profileUser.username %>" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm"/>
                </div>
                <div class="mb-4">
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">อีเมล</label>
                    <input type="email" name="email" value="<%= profileUser.email %>" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm"/>
                </div>
                <div class="mb-4">
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">รหัสผ่านใหม่</label>
                    <input type="password" name="password" value="" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm"/>
                </div>
                <button type="submit" class="w-full py-2.5 bg-blue-500 text-white text-sm font-semibold rounded-xl hover:bg-blue-600 transition">บันทึก</button>
            </form>
        </div>
        <div class="mt-4 text-center">
            <a href="/signout" class="text-xs text-gray-400 hover:text-red-500 transition">ออกจากระบบ</a>
        </div>
    </div>
</body>
</html>
