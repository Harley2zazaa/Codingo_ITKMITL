<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>รายละเอียดส่วนตัว - Codingo</title>
</head>
<body class="bg-white">
    <%- include('partials/navbar') %>
    <div class="max-w-xl mx-auto px-6 py-10 min-h-screen">
        <a href="/" class="text-sm text-gray-400 mb-6 inline-block">← ย้อนกลับ</a>
        <h1 class="text-3xl font-bold mb-8">รายละเอียดส่วนตัว</h1>
        <div class="bg-white border shadow-md rounded-2xl p-7">
            <div class="bg-white rounded-xl p-4 mb-6 border">
                <p class="text-sm text-gray-500 mt-1">คะแนนสะสม: <span class="text-orange-500 font-bold"><%= userData.score %> แต้ม</span></p>
            </div>
            <% if (error) { %>
                <div class="bg-red-900 border border-red-500 text-red-300 text-sm rounded-lg px-4 py-3 mb-5">
                    <%= error %>
                </div>
            <% } %>
            <% if (success) { %>
                <div class="bg-green-900 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">
                    <%= success %>
                </div>
            <% } %>
            <form action="/profile" method="POST">
                <div class="mb-5">
                    <label class="block text-sm text-gray-500 mb-1.5">ชื่อผู้ใช้</label>
                    <input type="text" name="username" value="<%= userData.username || '' %>" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none" placeholder="เช่น admin"/>
                </div>
                <div class="mb-5">
                    <label class="block text-sm text-gray-500 mb-1.5">อีเมล</label>
                    <input type="text" name="email" value="<%= userData.email || '' %>" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none" placeholder="เช่น admin@it.kmitl.ac.th"/>
                </div>
                <div class="flex items-center justify-between mt-6">
                    <button type="submit" class="bg-blue-500 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors">บันทึกการเปลี่ยนแปลง</button>
                    <a href="/logout" class="text-sm text-gray-500 hover:text-red-500 transition-colors">ออกจากระบบ</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
