<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Codingo — <%= lesson.title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { font-family: 'Sarabun', sans-serif; }
    details summary { cursor: pointer; list-style: none; }
    details summary::-webkit-details-marker { display: none; }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">

  <%- include('partials/navbar') %>

  <div class="max-w-3xl mx-auto px-6 py-10">

    <!-- ย้อนกลับ -->
    <a href="/" class="text-sm text-gray-400 hover:text-white mb-6 inline-block">← ย้อนกลับ</a>

    <!-- แจ้งเตือน -->
    <% if (msg === 'added')     { %><div class="bg-green-900/40 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">✅ เพิ่มบทเรียนเข้าคลังสำเร็จ (+50 แต้ม)</div><% } %>
    <% if (msg === 'removed')   { %><div class="bg-gray-700 border border-gray-500 text-gray-300 text-sm rounded-lg px-4 py-3 mb-5">ถอนบทเรียนออกจากคลังแล้ว</div><% } %>
    <% if (msg === 'already')   { %><div class="bg-yellow-900/40 border border-yellow-500 text-yellow-300 text-sm rounded-lg px-4 py-3 mb-5">⚠️ บทเรียนนี้อยู่ในคลังแล้ว</div><% } %>
    <% if (msg === 'completed') { %><div class="bg-green-900/40 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">✅ บันทึกความก้าวหน้าสำเร็จ (+20 แต้ม)</div><% } %>

    <!-- หัวบทเรียน -->
    <div class="bg-gray-800 border border-gray-700 rounded-2xl p-7 mb-6">
      <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-gray-700 text-gray-300"><%= lesson.category %></span>
      <h1 class="text-2xl font-bold text-white mt-3 mb-2"><%= lesson.title %></h1>
      <p class="text-gray-400 text-sm mb-5"><%= lesson.description %></p>

      <!-- ปุ่มคลัง -->
      <% if (user) { %>
        <% if (!inLibrary) { %>
          <form method="POST" action="/library/add/<%= lesson.id %>" class="inline">
            <button type="submit" class="bg-yellow-500 hover:bg-yellow-400 text-black text-sm font-semibold px-5 py-2 rounded-lg transition">
              + เพิ่มเข้าคลัง
            </button>
          </form>
        <% } else { %>
          <form method="POST" action="/library/remove/<%= lesson.id %>" class="inline"
            onsubmit="return confirm('ถอนบทเรียนนี้ออกจากคลังใช่หรือไม่?')">
            <button type="submit" class="bg-gray-700 hover:bg-red-900/50 border border-gray-600 hover:border-red-500 text-gray-300 hover:text-red-300 text-sm px-5 py-2 rounded-lg transition">
              ✕ ถอนจากคลัง
            </button>
          </form>
        <% } %>
        <% if (user.role === 'admin') { %>
          <a href="/admin/edit/<%= lesson.id %>" class="ml-2 text-sm text-purple-400 hover:text-purple-300">แก้ไขบทเรียน →</a>
          <a href="/admin/lesson/<%= lesson.id %>/contents" class="ml-3 text-sm text-purple-400 hover:text-purple-300">จัดการเนื้อหา →</a>
        <% } %>
      <% } else { %>
        <a href="/login" class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black text-sm font-semibold px-5 py-2 rounded-lg transition">
          เข้าสู่ระบบเพื่อเพิ่มเข้าคลัง
        </a>
      <% } %>
    </div>

    <!-- รายการเนื้อหา -->
    <h2 class="text-lg font-bold mb-4">เนื้อหาในบทเรียน (<%= contents.length %> บท)</h2>

    <% if (contents.length === 0) { %>
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-8 text-center text-gray-500">
        ไม่มีเนื้อหาบทเรียน
      </div>
    <% } else { %>
      <% contents.forEach((item, index) => { %>
        <%
          const isDone = completedIds.includes(item.id);
        %>
        <details class="bg-gray-800 border border-gray-700 rounded-xl mb-3 overflow-hidden group">
          <summary class="flex items-center gap-3 px-5 py-4 hover:bg-gray-700/50 transition">
            <span class="w-7 h-7 flex items-center justify-center rounded-full text-xs font-bold flex-shrink-0
              <%= isDone ? 'bg-green-500 text-white' : 'bg-gray-700 text-gray-400' %>">
              <%= isDone ? '✓' : index + 1 %>
            </span>
            <span class="font-semibold text-sm flex-1"><%= item.title %></span>
            <svg class="w-4 h-4 text-gray-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-2 border-t border-gray-700">
            <p class="text-gray-300 text-sm leading-relaxed mb-4"><%= item.body || 'ยังไม่มีเนื้อหา' %></p>
            <% if (user && inLibrary && !isDone) { %>
              <form method="POST" action="/progress/complete/<%= item.id %>">
                <button type="submit" class="text-xs bg-green-800/50 hover:bg-green-700/50 border border-green-600 text-green-300 px-4 py-1.5 rounded-lg transition">
                  ✓ ทำเครื่องหมายเสร็จสิ้น (+20 แต้ม)
                </button>
              </form>
            <% } else if (isDone) { %>
              <span class="text-xs text-green-400">✅ เรียนจบแล้ว</span>
            <% } %>
          </div>
        </details>
      <% }); %>
    <% } %>

  </div>
</body>
</html>
