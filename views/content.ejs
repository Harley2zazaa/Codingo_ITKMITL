<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title><%= course.title %> - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-3xl mx-auto px-6 py-10 min-h-screen">
        <a href="/<%- (user && inLibrary) ? 'library' : 'course' %>" class="text-sm text-gray-500 mb-6 inline-block">← ย้อนกลับ</a>
        <div class="bg-white border border-l-8 border-l-<%= course.color %>-500 shadow-md rounded-2xl p-7 mb-6">
            <span class="text-xs px-2.5 py-1 rounded-full bg-gray-700 text-white"><%= course.catagory_name %></span>
            <h1 class="text-2xl font-bold text-black mt-3 mb-2"><%= course.title %></h1>
            <p class="text-gray-500 text-sm mb-5"><%= course.description %></p>
            <% if (user) { %>
            <% if (!inLibrary) { %>
            <form method="POST" action="/course/add/<%= course.course_id %>" class="inline" onsubmit="return confirm('เพิ่มบทเรียนนี้เข้าในคลังใช่หรือไม่')">
                <button type="submit" class="bg-green-600 text-white text-sm px-5 py-2 rounded-lg">+ เพิ่มเข้าคลัง</button>
            </form>
            <% } else { %>
            <form method="POST" action="/library/remove/<%= course.course_id %>" class="inline" onsubmit="return confirm('ถอนบทเรียนนี้ออกจากคลังใช่หรือไม่')">
                <button type="submit" class="bg-red-600 text-white text-sm px-5 py-2 rounded-lg">✕ ถอนจากคลัง</button>
            </form>
            <% } %>
            <% } else { %>
            <a href="/signin" class="inline-block bg-gray-700 text-white text-sm px-5 py-2 rounded-lg">เข้าสู่ระบบ</a>
            <% } %>
        </div>
        <h2 class="text-lg font-bold mb-4">เนื้อหาในบทเรียน <%= contents.length %> บท</h2>
        <% if (contents.length == 0) { %>
            <div class="bg-white border shadow-md rounded-xl p-8 text-center text-gray-500">ไม่มีเนื้อหาบทเรียน</div>
        <% } else { %>
            <% contents.forEach((item, index) => { %>
                <% const isDone = completedIds && completedIds.includes(item.content_id) %>
                <% if (!user || !inLibrary) { %>
                <div class="flex items-center gap-3 px-5 py-4 bg-white border shadow-md rounded-xl mb-3">
                    <span class="w-7 h-7 flex items-center justify-center rounded-full text-xs flex-shrink-0 bg-gray-700 text-white"><%= index + 1 %></span>
                    <span class="font-semibold text-sm flex-1 text-black"><%= item.topic %></span>
                    <span class="text-gray-400 text-xs"><%= !user ? 'เข้าสู่ระบบ' : 'เพิ่มเข้าคลัง' %></span>
                </div>
                <% } else { %>
                <details class="bg-white border shadow-md rounded-xl mb-3 overflow-hidden group">
                    <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer">
                        <span class="w-7 h-7 flex items-center justify-center rounded-full text-xs flex-shrink-0 <%= isDone ? 'bg-green-500 text-white' : 'bg-gray-700 text-white' %>"><%= isDone ? '✓' : index + 1 %></span>
                        <span class="font-semibold text-sm flex-1"><%= item.topic %></span>
                    </summary>
                    <div class="px-5 pb-5 pt-2 border-t">
                        <p class="text-gray-500 text-sm leading-relaxed mb-4 whitespace-pre-line"><%= item.content || 'ยังไม่มีเนื้อหา' %></p>
                        <% if (item.Questions) { %>
                        <div class="bg-gray-50 border rounded-xl p-4 mb-4">
                            <p class="text-sm font-semibold text-gray-700 mb-3"><%= item.Questions %></p>
                            <form method="POST" action="/library/<%= course.course_id %>/<%= item.content_id %>">
                                <div class="grid grid-cols-1 gap-2 mb-3">
                                    <% [['A', item.A], ['B', item.B], ['C', item.C], ['D', item.D]].forEach(([key, val]) => { %>
                                        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                                            <input type="radio" name="answer" value="<%= key %>" class="accent-blue-500" />
                                            <span class="font-semibold"><%= key %>.</span> <%= val %>
                                        </label>
                                    <% }); %>
                                </div>
                                <button type="submit" class="mt-1 text-xs bg-blue-500 text-white px-4 py-1.5 rounded-lg">ส่งคำตอบ</button>
                            </form>
                            <% if (result && activeContent && activeContent.content_id == item.content_id) { %>
                                <p class="text-xs mt-2 <%= result == 'correct' ? 'text-green-600' : 'text-red-500' %>">
                                    <%= result == 'correct' ? '✓ ถูกต้อง! +10 XP' : '✗ ผิด ลองใหม่อีกครั้ง' %>
                                </p>
                            <% } %>
                        </div>
                        <% } %>
                        <% if (isDone) { %>
                            <span class="text-xs text-green-400">เรียนจบแล้ว ✓</span>
                        <% } %>
                    </div>
                </details>
                <% } %>
            <% }); %>
        <% } %>
    </div>
</body>
</html>
