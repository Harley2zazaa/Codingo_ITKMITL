<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>เข้าสู่ระบบ - Codingo</title>
</head>
<body class="bg-white min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <a href="/" class="text-sm text-gray-400 mb-6 inline-block">← ย้อนกลับ</a>
        <div class="text-center mb-8">
            <img src="/img/codingo_logo.png" class="h-16 mx-auto">
            <p class="text-gray-500 mt-1 text-sm">ระบบจัดการเรียนรู้ทักษะการเขียนโปรแกรมคอมพิวเตอร์</p>
        </div>
        <div class="bg-white border shadow-md rounded-2xl p-8">
            <h2 class="text-xl font-bold mb-6">เข้าสู่ระบบ</h2>
            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-5">
                    <%= error %>
                </div>
            <% } %>
            <form action="/login" method="POST">
                <div class="mb-4">
                    <label class="block text-sm text-gray-500 mb-2">อีเมล หรือ ชื่อผู้ใช้</label>
                    <input type="text" name="identifier" placeholder="name@email.com หรือ username" class="w-full bg-white border rounded-lg px-4 py-2 text-sm text-black placeholder-gray-500 focus:outline-none"/>
                </div>
                <div class="mb-6">
                    <label class="block text-sm text-gray-500 mb-2">รหัสผ่าน</label>
                    <input type="password" name="password" placeholder="**********" class="w-full bg-white border rounded-lg px-4 py-2 text-sm text-black placeholder-gray-500 focus:outline-none"/>
                </div>
                <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded-lg">เข้าสู่ระบบ</button>
            </form>
            <p class="text-center text-sm text-gray-500 mt-5">ยังไม่มีบัญชี? <a href="/register" class="text-blue-400 hover:underline">สมัครสมาชิก</a></p>
        </div>
    </div>
</body>
</html>
