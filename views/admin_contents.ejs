<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>จัดการเนื้อหา - Codingo</title>
</head>
<body class="bg-white">
    <%- include('partials/navbar') %>
    <div class="max-w-3xl mx-auto px-6 py-10 min-h-screen">
        <a href="/admin" class="text-sm text-gray-500 mb-6 inline-block">← กลับหน้าจัดการเนื้อหา</a>
        <h1 class="text-2xl font-bold mb-1">จัดการเนื้อหา</h1>
        <p class="text-gray-500 mb-8">บทเรียน: <span class="text-black font-semibold"><%= course.title %></span></p>
        <% if (msg == 'added')   { %><div class="bg-green-900/40 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">เพิ่มเนื้อหาสำเร็จ</div><% } %>
        <% if (msg == 'deleted') { %><div class="bg-gray-700 border border-gray-500 text-gray-300 text-sm rounded-lg px-4 py-3 mb-5">ลบเนื้อหาสำเร็จ</div><% } %>
        <% if (msg == 'error')   { %><div class="bg-red-900/40 border border-red-500 text-red-300 text-sm rounded-lg px-4 py-3 mb-5">ข้อมูลที่ต้องการยังไม่ครบถ้วน</div><% } %>
        <div class="bg-white border rounded-2xl p-6 mb-6">
            <h2 class="font-bold mb-4">เพิ่มเนื้อหาใหม่</h2>
            <form method="POST" action="/admin/course/<%= course.id %>/contents/add">
                <div class="mb-4">
                    <label class="block text-sm text-gray-500 mb-1.5">ชื่อเนื้อหา (บท) <span class="text-red-400">*</span></label>
                    <input type="text" name="title" placeholder="เช่น บทที่ 1 — บทนำ" required class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                </div>
                <div class="mb-4">
                    <label class="block text-sm text-gray-500 mb-1.5">เนื้อหา</label>
                    <textarea name="body" rows="4" placeholder="เนื้อหาของบทนี้..." class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none resize-none"></textarea>
                </div>
                <div class="border-t pt-4 mt-2 mb-4">
                    <p class="text-sm font-semibold text-gray-700 mb-3">แบบทดสอบ (ตัวเลือก)</p>
                    <div class="mb-3">
                        <label class="block text-sm text-gray-500 mb-1.5">คำถาม</label>
                        <input type="text" name="Questions" placeholder="คำถามแบบทดสอบ..." class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                    </div>
                    <div class="grid grid-cols-2 gap-3 mb-3">
                        <div>
                            <label class="block text-sm text-gray-500 mb-1.5">ตัวเลือก A</label>
                            <input type="text" name="A" placeholder="ตัวเลือก A" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-500 mb-1.5">ตัวเลือก B</label>
                            <input type="text" name="B" placeholder="ตัวเลือก B" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-500 mb-1.5">ตัวเลือก C</label>
                            <input type="text" name="C" placeholder="ตัวเลือก C" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-500 mb-1.5">ตัวเลือก D</label>
                            <input type="text" name="D" placeholder="ตัวเลือก D" class="w-full bg-white border rounded-lg px-4 py-2.5 text-sm text-black placeholder-gray-500 focus:outline-none" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm text-gray-500 mb-1.5">เฉลย (A, B, C หรือ D)</label>
                        <select name="Answer" class="w-32 bg-white border rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none">
                            <option value="">-- ไม่ระบุ --</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="C">C</option>
                            <option value="D">D</option>
                        </select>
                    </div>
                </div>
                <button type="submit" class="bg-blue-500 text-white px-5 py-2.5 rounded-lg text-sm">+ เพิ่มเนื้อหา</button>
            </form>
        </div>
        <h2 class="font-bold mb-4">เนื้อหาทั้งหมด (<%= contents.length %> บท)</h2>
        <% if (contents.length == 0) { %>
            <div class="text-center text-gray-500 py-10">ยังไม่มีเนื้อหา</div>
        <% } else { %>
            <div class="flex flex-col gap-3">
                <% contents.forEach((item, index) => { %>
                    <div class="bg-white border rounded-xl p-5">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex items-start gap-3 flex-1 min-w-0">
                                <span class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-full bg-gray-700 text-xs font-bold text-gray-300"><%= index + 1 %></span>
                                <div class="min-w-0 flex-1">
                                    <p class="font-semibold text-sm text-black"><%= item.title %></p>
                                    <p class="text-xs text-gray-500 mt-1 line-clamp-2"><%= item.body || '(ไม่มีเนื้อหา)' %></p>
                                    <% if (item.Questions) { %>
                                        <div class="mt-2 bg-gray-50 border rounded-lg px-3 py-2">
                                            <p class="text-xs font-semibold text-gray-600"><%= item.Questions %></p>
                                            <p class="text-xs text-gray-500 mt-1">A: <%= item.A %> &nbsp; B: <%= item.B %> &nbsp; C: <%= item.C %> &nbsp; D: <%= item.D %></p>
                                            <p class="text-xs text-green-600 font-semibold mt-1">เฉลย: <%= item.Answer %></p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                            <form action="/admin/contents/delete/<%= item.id %>" method="POST" onsubmit="return confirm('ลบเนื้อหานี้ใช่หรือไม่?')">
                                <button type="submit" class="text-xs px-3 py-1.5 bg-red-900 border border-red-800 rounded-md text-red-400 flex-shrink-0">ลบ</button>
                            </form>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
