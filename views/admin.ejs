<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Codingo — จัดการเนื้อหา</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>* { font-family: 'Sarabun', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">

  <%- include('partials/navbar') %>

  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold">จัดการเนื้อหา</h1>
        <p class="text-gray-400 mt-1">เพิ่ม แก้ไข และจัดการบทเรียนในระบบ</p>
      </div>
      <a href="/admin/add" class="bg-yellow-500 hover:bg-yellow-400 text-black font-semibold px-5 py-2.5 rounded-lg text-sm transition">
        + เพิ่มบทเรียนใหม่
      </a>
    </div>

    <!-- แจ้งเตือน -->
    <% if (msg === 'added')   { %><div class="bg-green-900/40 border border-green-500 text-green-300 text-sm rounded-lg px-4 py-3 mb-5">✅ เพิ่มบทเรียนสำเร็จ</div><% } %>
    <% if (msg === 'edited')  { %><div class="bg-blue-900/40 border border-blue-500 text-blue-300 text-sm rounded-lg px-4 py-3 mb-5">✅ แก้ไขบทเรียนสำเร็จ</div><% } %>
    <% if (msg === 'deleted') { %><div class="bg-gray-700 border border-gray-500 text-gray-300 text-sm rounded-lg px-4 py-3 mb-5">ลบบทเรียนสำเร็จ</div><% } %>

    <!-- ตารางบทเรียน -->
    <div class="bg-gray-800 border border-gray-700 rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="border-b border-gray-700">
          <tr class="text-left text-xs text-gray-500 uppercase tracking-wide">
            <th class="px-5 py-3">ชื่อบทเรียน</th>
            <th class="px-5 py-3">หมวดหมู่</th>
            <th class="px-5 py-3 text-center">เนื้อหา</th>
            <th class="px-5 py-3 text-right">การจัดการ</th>
          </tr>
        </thead>
        <tbody>
          <% if (lessons.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center text-gray-500 py-12">ยังไม่มีบทเรียนในระบบ</td>
            </tr>
          <% } %>
          <% lessons.forEach((item) => { %>
            <tr class="border-t border-gray-700/50 hover:bg-gray-700/30 transition">
              <td class="px-5 py-4 font-semibold text-white"><%= item.title %></td>
              <td class="px-5 py-4">
                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-700 text-gray-300"><%= item.category %></span>
              </td>
              <td class="px-5 py-4 text-center text-gray-400"><%= item.content_count %></td>
              <td class="px-5 py-4 text-right">
                <div class="flex justify-end gap-2">
                  <a href="/admin/lesson/<%= item.id %>/contents"
                    class="text-xs px-3 py-1.5 bg-gray-700 hover:bg-gray-600 rounded-md text-gray-300 transition">
                    เนื้อหา
                  </a>
                  <a href="/admin/edit/<%= item.id %>"
                    class="text-xs px-3 py-1.5 bg-blue-800/50 hover:bg-blue-700/50 border border-blue-700 rounded-md text-blue-300 transition">
                    แก้ไข
                  </a>
                  <form method="POST" action="/admin/delete/<%= item.id %>" class="inline"
                    onsubmit="return confirm('ลบบทเรียน \"<%= item.title %>\" ใช่หรือไม่?')">
                    <button type="submit"
                      class="text-xs px-3 py-1.5 bg-red-900/40 hover:bg-red-800/50 border border-red-800 rounded-md text-red-400 transition">
                      ลบ
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
