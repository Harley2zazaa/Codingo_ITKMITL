<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>จัดการบัญชี - Codingo</title>
</head>
<body class="bg-white">
    <%- include("partials/header") %>
    <div class="max-w-4xl mx-auto p-6 pt-24 min-h-screen">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-gray-800 text-3xl">จัดการบัญชี</h1>
                <p class="text-gray-600 mt-1">สร้าง แก้ไข และลบบัญชีในระบบ</p>
            </div>
            <a href="/admin/create" class="bg-green-600 text-white px-5 py-3 rounded-xl text-sm">สร้างบัญชี</a>
        </div>
        <div class="bg-white border rounded-xl overflow-hidden shadow-md">
            <table class="w-full text-sm">
                <tr class="text-xs text-gray-600 uppercase tracking-wide">
                    <th class="px-5 py-3 text-left">ชื่อผู้ใช้</th>
                    <th class="px-5 py-3 text-left">อีเมล</th>
                    <th class="px-5 py-3 text-center">บทบาท</th>
                    <th class="px-5 py-3 text-right">การจัดการ</th>
                </tr>
                <% accounts.forEach((item) => { %>
                <tr class="border-t">
                    <td class="px-5 py-3 text-left text-gray-800"><%= item.username %></td>
                    <td class="px-5 py-3 text-left text-gray-800"><%= item.email %></td>
                    <td class="px-5 py-3 text-center"><span class="text-xs px-3 py-1 rounded-full bg-gray-800 text-white"><%= item.role %></span></td>
                    <td class="px-5 py-3 text-right">
                        <div class="flex justify-end gap-2">
                            <a href="/admin/edit/<%= item.account_id %>" class="text-xs px-3 py-2 bg-blue-600 rounded-xl text-white">แก้ไขบัญชี</a>
                            <form action="/admin/delete/<%= item.account_id %>" method="POST" class="inline" onsubmit="return confirm('ต้องการลบบัญชี <%= item.username %> ใช่หรือไม่?')">
                                <button type="submit" class="text-xs px-3 py-2 bg-red-600 border border-red-600 rounded-xl text-white">ลบ</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </table>
        </div>
    </div>
    <% if (success === 'created') { %>
    <script>alert("สร้างบัญชีสำเร็จ");</script>
    <% } else if (success === 'deleted') { %>
    <script>alert("ลบบัญชีสำเร็จ");</script>
    <% } %>
</body>
</html>
