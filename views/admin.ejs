<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>จัดการเนื้อหา - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/navbar') %>
    <div class="max-w-5xl mx-auto px-6 py-10 min-h-screen">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold">จัดการเนื้อหา</h1>
                <p class="text-gray-500 mt-1">เพิ่ม แก้ไข และจัดการบทเรียนในระบบ</p>
            </div>
            <a href="/admin/add" class="bg-blue-500 text-white px-5 py-2 rounded-lg text-sm transition">+ เพิ่มบทเรียนใหม่</a>
        </div>
        <% if (msg == 'added')   { %><div class="bg-green-900 border border-green-500 text-green-500 text-sm rounded-lg px-4 py-3 mb-5">เพิ่มบทเรียนสำเร็จ</div><% } %>
        <% if (msg == 'edited')  { %><div class="bg-blue-900 border border-blue-500 text-blue-500 text-sm rounded-lg px-4 py-3 mb-5">แก้ไขบทเรียนสำเร็จ</div><% } %>
        <% if (msg == 'deleted') { %><div class="bg-red-700 border border-gray-500 text-gray-500 text-sm rounded-lg px-4 py-3 mb-5">ลบบทเรียนสำเร็จ</div><% } %>
        <div class="bg-white border rounded-2xl overflow-hidden">
            <table class="w-full text-sm">
                <thead class="border-b">
                    <tr class="text-left text-xs text-gray-500 uppercase tracking-wide">
                        <th class="px-5 py-3">ชื่อบทเรียน</th>
                        <th class="px-5 py-3">หมวดหมู่</th>
                        <th class="px-5 py-3 text-center">เนื้อหา</th>
                        <th class="px-5 py-3 text-right">การจัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (course.length == 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-gray-500 py-12">ยังไม่มีบทเรียนในระบบ</td>
                        </tr>
                    <% } %>
                    <% course.forEach((item) => { %>
                        <tr class="border-t">
                            <td class="px-5 py-4 font-semibold text-black"><%= item.title %></td>
                            <td class="px-5 py-4">
                                <span class="text-xs px-2.5 py-1 rounded-full text-white" style="background-color: <%= item.color || '#374151' %>"><%= item.category %></span>
                            </td>
                            <td class="px-5 py-4 text-center text-gray-500"><%= item.content_count %></td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a href="/admin/edit/course/<%= item.id %>" class="text-xs px-3 py-1.5 bg-gray-700 rounded-md text-gray-300">แก้ไขบทเรียน</a>
                                    <a href="/admin/edit/course/<%= item.id %>/content" class="text-xs px-3 py-1.5 bg-gray-700 rounded-md text-gray-300">จัดการเนื้อหา</a>
                                    <form action="/admin/delete/course/<%= item.id %>" method="POST" class="inline" onsubmit="return confirm('ต้องการลบบทเรียน <%= item.title %> ใช่หรือไม่?')">
                                        <button type="submit" class="text-xs px-3 py-1.5 bg-red-900 border border-red-800 rounded-md text-red-400">ลบ</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
