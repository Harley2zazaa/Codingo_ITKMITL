<nav class="bg-white border-b px-6 py-3 fixed top-0 left-0 w-full z-50">
    <div class="flex justify-between">
        <a href="/" class="flex items-center">
            <img src="/img/codingo_logo.png" class="h-10 w-auto">
        </a>
        <div class="flex items-center gap-2">
            <a href="/search" class="px-1 py-2 text-sm text-black">ค้นหา</a>
