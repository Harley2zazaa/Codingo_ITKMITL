            <% } %>
                <a href="/profile" class="px-3 py-2 text-sm bg-gray-700 text-white rounded-lg"><%= user.nickname || user.username %><span class="text-orange-500 ml-1 text-xs"><%= user.score %> คะแนน</span></a>
            <% } else { %>
                <a href="/login" class="px-3 py-2 text-sm bg-blue-500 text-white rounded-lg">เข้าสู่ระบบ</a>
            <% } %>
        </div>
    </div>
</nav>
