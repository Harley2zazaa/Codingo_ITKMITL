<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>คลังส่วนตัว - Codingo</title>
</head>
<body class="bg-white">
    <%- include('partials/header') %>
    <div class="max-w-6xl mx-auto p-6 pt-24 min-h-screen">
        <h1 class="text-3xl mb-2">คลังส่วนตัว</h1>
        <p class="text-gray-600 mb-8">บทเรียนที่คุณเพิ่มไว้</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            <% courses.forEach((item) => { %>
            <a href="/library/<%= item.course_id %>" class="bg-white border border-l-8 border-l-<%= item.color %>-600 rounded-xl shadow-md p-6 overflow-hidden">
                <span class="text-xs px-3 py-1 rounded-full bg-gray-800 text-white"><%= item.catagory_name %></span>
                <div class="flex items-center justify-between mt-3">
                    <h2 class="text-gray-800 mb-1"><%= item.title %></h2>
                    <span class="text-xs text-gray-600"><%= item.done %>/<%= item.total %></span>
                </div>
                <p class="text-sm text-gray-600 line-clamp-2"><%= item.description %></p>
                <div class="mt-3 w-full bg-gray-600 rounded-full">
                    <% let percent = Math.round((item.done / item.total) * 100); %>
                    <% let tagColor = percent < 25 ? "red": percent < 50 ? "orange": percent < 75 ? "yellow": "green"; %>
                    <div class="bg-<%= tagColor %>-600 h-1.5 rounded-full" style="width: <%= percent %>%"></div>
                </div>
            </a>
            <% }); %>
        </div>
    </div>
</body>
</html>
