<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>คลังส่วนตัว - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-6xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-2">คลังส่วนตัว</h1>
        <p class="text-gray-500 mb-8">บทเรียนที่คุณเพิ่มไว้</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            <% courses.forEach((item) => { %>
                <a href="/library/<%= item.course_id %>" class="block bg-white border border-l-8 border-l-<%= item.color %>-500 rounded-xl shadow-md overflow-hidden">
                    <div class="p-5">
                        <h2 class="font-bold text-base text-black mb-1"><%= item.title %></h2>
                        <div class="flex items-center justify-between my-2">
                            <span class="text-xs px-2 py-1 rounded-full bg-gray-700 text-white"><%= item.catagory_name %></span>
                            <span class="text-xs text-gray-500"><%= item.done %>/<%= item.total %> บท</span>
                        </div>
                        <p class="text-sm text-gray-500 line-clamp-2"><%= item.description %></p>
                        <% if (item.total > 0) { %>
                        <div class="mt-3 w-full bg-gray-100 rounded-full h-1.5">
                            <% let percent = Math.round((item.done / item.total) * 100); %>
                            <% let pccolor = percent < 25 ? "red": percent < 50 ? "orange": percent < 75 ? "yellow": "green"; %>
                            <div class="bg-<%= pccolor %>-500 h-1.5 rounded-full" style="width: <%= percent %>%"></div>
                        </div>
                        <% } %>
                    </div>
                </a>
            <% }); %>
        </div>
    </div>
</body>
</html>
