<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>คลังส่วนตัว - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/navbar') %>
    <div class="max-w-6xl mx-auto px-6 py-10 min-h-screen">
        <h1 class="text-3xl font-bold mb-2">คลังส่วนตัว</h1>
        <p class="text-gray-500 mb-8">บทเรียนที่คุณเพิ่มไว้</p>
        <% if (empty) { %>
            <div class="text-center py-24">
                <p class="text-black text-lg font-semibold">ยังไม่มีบทเรียนในคลัง</p>
                <p class="text-gray-600 text-sm mt-1">ไปค้นหาบทเรียนที่สนใจ แล้วกด "เพิ่มเข้าคลัง"</p>
                <a href="/search" class="inline-block mt-5 bg-blue-500 text-white px-6 py-2.5 rounded-lg text-sm">ค้นหาบทเรียน</a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                <% course.forEach((item) => { %>
                    <a href="/course/<%= item.id %>" class="block bg-white border border-l-8 border-l-<%= item.color %>-500 rounded-xl shadow-md overflow-hidden">
                        <div class="p-5">
                            <h2 class="font-bold text-base text-black mb-1"><%= item.title %></h2>
                            <div class="flex items-center justify-between my-2">
                                <span class="text-xs px-2 py-1 rounded-full bg-gray-700 text-white"><%= item.category %></span>
                                <span class="text-xs text-gray-500"><%= item.content_count %> หัวข้อ</span>
                            </div>
                            <p class="text-sm text-gray-500 line-clamp-2"><%= item.description %></p>
                        </div>
                    </a>
                <% }); %>
            </div>
        <% } %>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
