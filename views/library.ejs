<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Codingo — คลังส่วนตัว</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>* { font-family: 'Sarabun', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">

  <%- include('partials/navbar') %>

  <div class="max-w-6xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold mb-2">คลังส่วนตัว</h1>
    <p class="text-gray-400 mb-8">บทเรียนที่คุณเพิ่มไว้</p>

    <% if (empty) { %>
      <div class="text-center py-24">
        <p class="text-5xl mb-3">📚</p>
        <p class="text-gray-400 text-lg font-semibold">ยังไม่มีบทเรียนในคลัง</p>
        <p class="text-gray-600 text-sm mt-1">ไปค้นหาบทเรียนที่สนใจ แล้วกด "เพิ่มเข้าคลัง"</p>
        <a href="/search" class="inline-block mt-5 bg-yellow-500 hover:bg-yellow-400 text-black font-semibold px-6 py-2.5 rounded-lg text-sm transition">
          ค้นหาบทเรียน
        </a>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% lessons.forEach((item) => { %>
          <%
            const pct = item.content_count > 0 ? Math.round((item.done / item.content_count) * 100) : 0;
          %>
          <a href="/lessons/<%= item.id %>" class="block bg-gray-800 border border-gray-700 rounded-xl hover:border-yellow-400 transition-all overflow-hidden">
            <div class="h-2 w-full"
              style="background: <%= item.category === 'Python' ? '#3b82f6' : item.category === 'JavaScript' ? '#f59e0b' : item.category === 'Web' ? '#f97316' : item.category === 'Database' ? '#10b981' : item.category === 'DevTools' ? '#8b5cf6' : item.category === 'Backend' ? '#06b6d4' : item.category === 'Computer Science' ? '#ec4899' : '#6b7280' %>">
            </div>
            <div class="p-5">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs px-2 py-0.5 rounded-full bg-gray-700 text-gray-300"><%= item.category %></span>
                <span class="text-xs text-gray-500"><%= item.done %>/<%= item.content_count %> บท</span>
              </div>
              <h2 class="font-bold text-white mb-3"><%= item.title %></h2>
              <!-- Progress bar -->
              <div class="h-1.5 bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all
                  <%= pct === 100 ? 'bg-green-500' : 'bg-yellow-500' %>"
                  style="width: <%= pct %>%">
                </div>
              </div>
              <p class="text-xs text-gray-500 mt-1.5"><%= pct %>% เสร็จสิ้น</p>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
