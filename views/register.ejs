<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>สมัครสมาชิก - Codingo</title>
</head>
<body class="bg-white min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <a href="/" class="text-sm text-gray-400 mb-6 inline-block">← ย้อนกลับ</a>
        <div class="text-center mb-8">
            <img src="/img/codingo_logo.png" class="h-16 mx-auto">
            <p class="text-gray-500 mt-1 text-sm">ระบบจัดการเรียนรู้ทักษะการเขียนโปรแกรมคอมพิวเตอร์</p>
        </div>
        <div class="bg-white border shadow-md rounded-2xl p-8">
            <h2 class="text-xl font-bold mb-6">สมัครสมาชิก</h2>
            <form action="/register" method="POST">
                <div class="mb-4">
                    <label class="block text-sm text-gray-500 mb-2">ชื่อผู้ใช้</label>
                    <input type="text" name="username" placeholder="ชื่อผู้ใช้ของคุณ" class="w-full bg-white border rounded-lg px-4 py-2 text-sm text-black placeholder-gray-500 focus:outline-none" required/>
                </div>
                <div class="mb-4">
                    <label class="block text-sm text-gray-500 mb-2">อีเมล</label>
                    <input type="email" name="email" placeholder="e.g. your@email.com" class="w-full bg-white border rounded-lg px-4 py-2 text-sm text-black placeholder-gray-500 focus:outline-none" required/>
                </div>
                <div class="mb-6">
                    <label class="block text-sm text-gray-500 mb-2">รหัสผ่าน</label>
                    <input type="password" name="password" placeholder="อย่างน้อย 6 ตัวอักษร" class="w-full bg-white border rounded-lg px-4 py-2 text-sm text-black placeholder-gray-500 focus:outline-none" required/>
                </div>
                <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded-lg">สมัครสมาชิก</button>
            </form>
            <p class="text-center text-sm text-gray-500 mt-5">มีบัญชีแล้ว? <a href="/login" class="text-blue-400 hover:underline">เข้าสู่ระบบ</a></p>
        </div>
    </div>
</body>
</html>
