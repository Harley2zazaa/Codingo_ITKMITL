<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Codingo — สมัครสมาชิก</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>* { font-family: 'Sarabun', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen flex items-center justify-center px-4">

  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold">Co<span class="text-yellow-400">dingo</span></h1>
      <p class="text-gray-400 mt-1 text-sm">ระบบจัดการการเรียนรู้</p>
    </div>

    <div class="bg-gray-800 border border-gray-700 rounded-2xl p-8">
      <h2 class="text-xl font-bold mb-6">สมัครสมาชิก</h2>

      <% if (error) { %>
        <div class="bg-red-900/40 border border-red-500 text-red-300 text-sm rounded-lg px-4 py-3 mb-5">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/register">
        <div class="mb-4">
          <label class="block text-sm text-gray-400 mb-1.5">ชื่อผู้ใช้</label>
          <input type="text" name="username" placeholder="ชื่อผู้ใช้ของคุณ" required
            class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400" />
        </div>
        <div class="mb-4">
          <label class="block text-sm text-gray-400 mb-1.5">อีเมล</label>
          <input type="email" name="email" placeholder="e.g. your@email.com" required
            class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400" />
        </div>
        <div class="mb-6">
          <label class="block text-sm text-gray-400 mb-1.5">รหัสผ่าน</label>
          <input type="password" name="password" placeholder="อย่างน้อย 6 ตัวอักษร" required
            class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400" />
        </div>
        <button type="submit"
          class="w-full bg-yellow-500 hover:bg-yellow-400 text-black font-semibold py-2.5 rounded-lg transition">
          สมัครสมาชิก
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-5">
        มีบัญชีแล้ว? <a href="/login" class="text-yellow-400 hover:underline">เข้าสู่ระบบ</a>
      </p>
    </div>
  </div>

</body>
</html>
