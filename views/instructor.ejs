<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('partials/head') %>
    <title>จัดการเนื้อหา - Codingo</title>
</head>
<body class="bg-white pt-16">
    <%- include('partials/header') %>
    <div class="max-w-5xl mx-auto px-6 py-10 min-h-screen">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold">จัดการเนื้อหา</h1>
                <p class="text-gray-500 mt-1">เพิ่ม แก้ไข และจัดการบทเรียนในระบบ</p>
            </div>
            <a href="/instructor/create" class="bg-green-600 text-white px-5 py-2 rounded-lg text-sm transition">+ เพิ่มบทเรียนใหม่</a>
        </div>
        <div class="bg-white border rounded-2xl overflow-hidden">
            <table class="w-full text-sm">
                <thead class="border-b">
                    <tr class="text-left text-xs text-gray-500 uppercase tracking-wide">
                        <th class="px-5 py-3">ชื่อบทเรียน</th>
                        <th class="px-5 py-3">หมวดหมู่</th>
                        <th class="px-5 py-3 text-center">เนื้อหา</th>
                        <th class="px-5 py-3 text-right">การจัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (courses.length == 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-gray-500 py-12">ยังไม่มีบทเรียนในระบบ</td>
                        </tr>
                    <% } %>
                    <% courses.forEach((item) => { %>
                        <tr class="border-t">
                            <td class="px-5 py-4 font-semibold text-black"><%= item.title %></td>
                            <td class="px-5 py-4">
                                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-700 text-white"><%= item.catagory_name %></span>
                            </td>
                            <td class="px-5 py-4 text-center text-gray-500"><%= item.content_count %></td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a href="/instructor/edit/<%= item.course_id %>" class="text-xs px-3 py-1.5 bg-gray-700 rounded-md text-white">แก้ไขบทเรียน</a>
                                    <form action="/instructor/delete/<%= item.course_id %>" method="POST" class="inline" onsubmit="return confirm('ต้องการลบบทเรียน <%= item.title %> ใช่หรือไม่?')">
                                        <button type="submit" class="text-xs px-3 py-1.5 bg-red-600 border border-red-600 rounded-md text-white">ลบ</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
