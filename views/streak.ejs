<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head") %>
    <title>วันติดต่อกัน - Codingo</title>
</head>
<body class="bg-white">
    <div class="flex items-center justify-center min-h-screen">
        <div class="text-center px-6">
            <div class="text-9xl mb-4 animate-bounce">🔥</div>
            <p class="text-orange-600 text-sm mb-1">วันติดต่อกัน</p>
            <h1 class="text-9xl text-gray-800 mb-1"><%= gamificate.streak %></h1>
            <p class="text-sm text-gray-600 mb-8">Day Streak</p>
            <div class="inline-flex items-center gap-2 bg-gray-800 rounded-xl px-4 py-3 mb-8">
                <span class="text-white text-sm">เข้าใช้ล่าสุด</span>
                <span class="text-white text-sm"><%= gamificate.last_active %></span>
            </div>
            <p class="text-gray-600 text-md mb-10">
                "<% let streak = gamificate.streak;
                    let message = "";
                    if (streak <= 1) {
                        message = "<del>NOOB</del> KEEP UP";
                    }
                    else if (streak < 7) {
                        message = "PRO";
                    }
                    else if (streak < 30) {
                        message = "HACK";
                    }
                    else {
                        message = "GOD";
                    } %>
                <%- message %>" - Sarin said
            </p>
            <a href="/home" class="bg-orange-600 text-white text-sm px-4 py-3 rounded-xl">กลับไปหน้าหลัก</a>
        </div>
    </div>
</body>
</html>
